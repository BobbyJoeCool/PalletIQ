datasource db {
  provider = "sqlserver"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// ─── Lookup tables ───────────────────────────────────────────────────────────

model StorageCode {
  id   String @id @db.NVarChar(2)
  desc String @db.NVarChar(60)

  items     Item[]
  locations Location[]
  pallets   Pallet[]
}

model Department {
  id   String @id @db.NVarChar(3)
  name String @db.NVarChar(60)

  users User[]
}

model HoldType {
  code String @id @db.NVarChar(3)
  desc String @db.NVarChar(20)

  locations Location[]
}

model PackingZone {
  id   Int    @id
  desc String @db.NVarChar(60)

  items Item[]
}

model Store {
  id   Int    @id
  name String @db.NVarChar(40)

  labels Label[]
}

// ─── Core models ─────────────────────────────────────────────────────────────

model Item {
  dept                   Int
  class                  Int
  item                   Int
  upc                    String   @unique @db.NVarChar(12)
  name                   String   @db.NVarChar(50)
  desc                   String   @db.NVarChar(Max)
  descShort              String   @db.NVarChar(155)
  retailPrice            Decimal  @db.Decimal(10, 2)
  cost                   Decimal  @db.Decimal(10, 2)
  packingZoneCode        Int
  storageCode            String   @db.NVarChar(2)
  conveyable             Boolean  @default(true)
  // Per-DPCI setting (not derived from Storage Code) — food items are seeded true, but this
  // is meant to be configurable per item rather than a blanket category rule. Drives PII's
  // Expiration Date requirement messaging on pallets of this item; the pallet's own
  // `expirationDate` stays nullable at the DB level regardless (see Pallet.expirationDate).
  requiresExpirationDate Boolean  @default(false)
  // v1.6.8 — displayed on IID; nullable since not every item has been weighed yet. Pounds,
  // 2 decimal places.
  unitWeight             Decimal? @db.Decimal(10, 2)

  packingZone PackingZone @relation(fields: [packingZoneCode], references: [id])
  storageRef  StorageCode @relation(fields: [storageCode], references: [id])

  pallets      Pallet[]
  labels       Label[]
  activityLogs ActivityLog[]

  @@id([dept, class, item], name: "DPCI")
}

model Location {
  aisle        Int
  bin          Int
  level        Int
  zone         Int
  status       String  @db.NVarChar(15)
  // holdTypeCode is a reason-code FK (1-letter dept + 2-digit reason, e.g. "B05" — see
  // HoldType below), not the hold category. Left unpopulated per WLH.md, which states
  // twice that the reason code is written only to the ActivityLog, not stored as a
  // column — kept in the schema as inherited, currently-unused infrastructure rather
  // than removed outright (Phase 10, see phase-10 log).
  holdTypeCode String? @db.NVarChar(3)
  storageCode  String  @db.NVarChar(2)
  size         String  @db.NVarChar(2)
  // Contraction is set at zone-side+level granularity by Lead+ via Aisle Setup (out of
  // scope for this demo — see ELZ.md); stored per-location and expected to be uniform
  // across every location sharing a zone-side/level group. Read-only in this app.
  contraction  Boolean @default(false)
  // The hold *category* (HOLD_IN/HOLD_OUT/HOLD_BOTH/HOLD_PERM), independent of `status`
  // per outline.md's original Location description ("HoldType, nullable, independent of
  // Status"). Added Phase 10 — `status` briefly (Phase 6's blockPut) doubled as the hold
  // indicator, which destroys the location's real operational state (EMPTY vs STORED)
  // the moment a hold is placed; fixed to use this field instead. See phase-10 log.
  holdCategory String? @db.NVarChar(10)

  holdType   HoldType?   @relation(fields: [holdTypeCode], references: [code])
  storageRef StorageCode @relation(fields: [storageCode], references: [id])

  pallets      Pallet[]
  reservations Reservation[]
  activityLogs ActivityLog[]

  @@id([aisle, bin, level], name: "LocationID")
}

model User {
  zNumber      String @id @db.NVarChar(7)
  firstName    String @db.NVarChar(50)
  lastName     String @db.NVarChar(50)
  pinHash      String @db.NVarChar(60)
  role         String @db.NVarChar(10)
  departmentId String @db.NVarChar(3)

  department Department @relation(fields: [departmentId], references: [id])

  receivedPallets Pallet[]      @relation("PalletReceivedBy")
  putPallets      Pallet[]      @relation("PalletPutBy")
  pulledPallets   Pallet[]      @relation("PalletLastPulledBy")
  reservations    Reservation[]
  activityLogs    ActivityLog[]
}

model Pallet {
  pid             Int       @id
  dept            Int
  class           Int
  item            Int
  receivedPallets Int
  currentPallets  Int
  receivedCartons Int
  currentCartons  Int
  receivedSSPs    Int
  currentSSPs     Int
  // How many cartons make up ONE full pallet of this quantity — a fixed snapshot taken at
  // creation (receiving or PAR reinstate), never updated afterward as currentCartons
  // depletes. Added for PAR's v1.6.11 redesign as groundwork for Bulk locations (multiple
  // full pallets + a partial sharing one location) — every pallet gets this now, not just
  // PAR-created ones, backfilled onto pre-existing rows. Rounding rule when derived from a
  // cartons+loose-SSPs pair: wholeCartons + (looseSSPs > 0 ? 1 : 0) — a flat +1 if there's
  // any loose-SSP remainder, not a fractional/ratio-based calculation. `editPallet`'s
  // INSUFFICIENT_QUANTITY check previously used receivedCartons as a stand-in for this
  // exact concept (see that handler's own comment) — now reads this field directly instead.
  cartonsPerPallet Int      @default(0)
  vcp             Int
  ssp             Int
  status          String    @db.NVarChar(15)
  locationAisle   Int?
  locationBin     Int?
  locationLevel   Int?
  // The pallet's own Storage Code/Size/Zone — always copied from wherever it's currently
  // STORED (set in placePallet, every time a put/move completes), null while PUT_PENDING
  // (never stored, nothing to inherit from). This is the source of truth Directed Put's
  // default location search reads from when no IM+ override is given: exact-match
  // Storage Code/Size, and Zone as the search's starting point (falling back to Zone 1 if
  // that exact zone has no eligible location — see zoneLogic.ts). Denormalized from
  // Location rather than joined live, since a pallet's put history (and thus its most
  // recent location) can't be reconstructed from Location alone once it moves again.
  storageCode     String?   @db.NVarChar(2)
  size            String?   @db.NVarChar(2)
  zone            Int?
  receivedByZ     String    @db.NVarChar(7)
  receivedAt      DateTime
  putByZ          String?   @db.NVarChar(7)
  putAt           DateTime?
  lastPulledByZ   String?   @db.NVarChar(7)
  lastPulledAt    DateTime?
  // Receiving-side identifiers (PO = Product Order, Appointment = the trailer the pallet was
  // received on) — set once at receiving, never edited from PII. Null for a pallet created
  // manually via PAR rather than through a real receiving event (see pallets.ts's reinstate
  // handler). No format validation enforced (read-only from every screen today).
  poNumber        String?   @db.NVarChar(20)
  apptNumber      String?   @db.NVarChar(20)
  // Nullable regardless of the item's own `requiresExpirationDate` — PII surfaces that as a
  // prompt/requirement in the UI, not a DB constraint. Editable via PII's Edit Mode (IM+):
  // must be at least 1 month out (else blocked) and gets a confirm-step warning inside 3
  // months — see PATCH /api/pallets/:id.
  expirationDate  DateTime? @db.Date

  itemRef      Item         @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
  location     Location?    @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  storageRef   StorageCode? @relation(fields: [storageCode], references: [id])
  receivedBy   User         @relation("PalletReceivedBy", fields: [receivedByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  putBy        User?        @relation("PalletPutBy", fields: [putByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  lastPulledBy User?        @relation("PalletLastPulledBy", fields: [lastPulledByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)

  labels       Label[]
  reservations Reservation[]
  activityLogs ActivityLog[]
}

model Label {
  lid              String   @id @db.NVarChar(36)
  pid              Int
  dept             Int
  class            Int
  item             Int
  quantity         Int
  sspQuantity      Int
  batchDate        Int
  purgeDate        DateTime @db.Date
  destinationStore Int
  status           String   @db.NVarChar(15)
  pullFunction     String   @db.NVarChar(2)

  pallet  Pallet @relation(fields: [pid], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  itemRef Item   @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
  store   Store  @relation(fields: [destinationStore], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// Tracks active SDP reservations. One row per in-flight reservation; deleted on resolution.
model Reservation {
  id            Int      @id @default(autoincrement())
  locationAisle Int
  locationBin   Int
  locationLevel Int
  palletId      Int
  workerZ       String   @db.NVarChar(7)
  // Original search criteria — preserved so block/find-next can re-run the same query.
  targetAisle   Int
  targetSize    String?  @db.NVarChar(2)
  targetStorage String?  @db.NVarChar(2)
  targetZone    Int?
  // Preserved from the original directedPut call so a Blocked Put re-search (blockPut)
  // honors the same STAGED-exclusion preference as the initial search.
  consolidating Boolean  @default(false)
  // Whether the Pallet ID that started this reservation was scanned or hand-typed —
  // carried through to confirmPut's activity log entry as the PUT's verification-method
  // record (paired with confirmPut's own scanned-vs-typed read of the location-confirm
  // field). Nullable for migration safety on any pre-existing row, though every reservation
  // directedPut creates from here on always sets it explicitly.
  pidWasScanned Boolean?
  // True if findNextLocation matched this reservation's location via the STAGED search
  // (the preferred/expected outcome), false if it fell through to the EMPTY search —
  // carried through to confirmPut, since by confirm time the location's live status is
  // already RESERVED, not useful for telling which search path originally matched it.
  // Nullable for migration safety on any pre-existing row; every reservation directedPut
  // creates from here on always sets it explicitly.
  wasStaged     Boolean?
  createdAt     DateTime @default(now())

  location Location @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  pallet   Pallet   @relation(fields: [palletId], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  worker   User     @relation(fields: [workerZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
}

model ActivityLog {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime @default(now())
  userId        String   @db.NVarChar(7)
  actionType    String   @db.NVarChar(10)
  palletId      Int?
  locationAisle Int?
  locationBin   Int?
  locationLevel Int?
  dept          Int?
  class         Int?
  item          Int?
  details       String?  @db.NVarChar(Max)

  user     User      @relation(fields: [userId], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  pallet   Pallet?   @relation(fields: [palletId], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  location Location? @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  itemRef  Item?     @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
}
