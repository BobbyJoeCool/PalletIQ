datasource db {
  provider = "sqlserver"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// ─── Lookup tables ───────────────────────────────────────────────────────────

model StorageCode {
  id   String @id @db.NVarChar(2)
  desc String @db.NVarChar(60)

  items     Item[]
  locations Location[]
}

model Department {
  id   String @id @db.NVarChar(3)
  name String @db.NVarChar(60)

  users User[]
}

model HoldType {
  code String @id @db.NVarChar(3)
  desc String @db.NVarChar(20)

  locations Location[]
}

model PackingZone {
  id   Int    @id
  desc String @db.NVarChar(60)

  items Item[]
}

model Store {
  id   Int    @id
  name String @db.NVarChar(40)

  labels Label[]
}

// ─── Core models ─────────────────────────────────────────────────────────────

model Item {
  dept            Int
  class           Int
  item            Int
  upc             String  @unique @db.NVarChar(12)
  name            String  @db.NVarChar(50)
  desc            String  @db.NVarChar(Max)
  descShort       String  @db.NVarChar(155)
  retailPrice     Decimal @db.Decimal(10, 2)
  cost            Decimal @db.Decimal(10, 2)
  packingZoneCode Int
  storageCode     String  @db.NVarChar(2)
  conveyable      Boolean @default(true)

  packingZone PackingZone @relation(fields: [packingZoneCode], references: [id])
  storageRef  StorageCode @relation(fields: [storageCode], references: [id])

  pallets      Pallet[]
  labels       Label[]
  activityLogs ActivityLog[]

  @@id([dept, class, item], name: "DPCI")
}

model Location {
  aisle        Int
  bin          Int
  level        Int
  zone         Int
  status       String  @db.NVarChar(15)
  // holdTypeCode is a reason-code FK (1-letter dept + 2-digit reason, e.g. "B05" — see
  // HoldType below), not the hold category. Left unpopulated per WLH.md, which states
  // twice that the reason code is written only to the ActivityLog, not stored as a
  // column — kept in the schema as inherited, currently-unused infrastructure rather
  // than removed outright (Phase 10, see phase-10 log).
  holdTypeCode String? @db.NVarChar(3)
  storageCode  String  @db.NVarChar(2)
  size         String  @db.NVarChar(2)
  // Contraction is set at zone-side+level granularity by Lead+ via Aisle Setup (out of
  // scope for this demo — see ELZ.md); stored per-location and expected to be uniform
  // across every location sharing a zone-side/level group. Read-only in this app.
  contraction  Boolean @default(false)
  // The hold *category* (HOLD_IN/HOLD_OUT/HOLD_BOTH/HOLD_PERM), independent of `status`
  // per outline.md's original Location description ("HoldType, nullable, independent of
  // Status"). Added Phase 10 — `status` briefly (Phase 6's blockPut) doubled as the hold
  // indicator, which destroys the location's real operational state (EMPTY vs STORED)
  // the moment a hold is placed; fixed to use this field instead. See phase-10 log.
  holdCategory String? @db.NVarChar(10)

  holdType   HoldType?   @relation(fields: [holdTypeCode], references: [code])
  storageRef StorageCode @relation(fields: [storageCode], references: [id])

  pallets      Pallet[]
  reservations Reservation[]
  activityLogs ActivityLog[]

  @@id([aisle, bin, level], name: "LocationID")
}

model User {
  zNumber      String @id @db.NVarChar(7)
  firstName    String @db.NVarChar(50)
  lastName     String @db.NVarChar(50)
  pinHash      String @db.NVarChar(60)
  role         String @db.NVarChar(10)
  departmentId String @db.NVarChar(3)

  department Department @relation(fields: [departmentId], references: [id])

  receivedPallets Pallet[]      @relation("PalletReceivedBy")
  putPallets      Pallet[]      @relation("PalletPutBy")
  pulledPallets   Pallet[]      @relation("PalletLastPulledBy")
  reservations    Reservation[]
  activityLogs    ActivityLog[]
}

model Pallet {
  pid             Int       @id
  dept            Int
  class           Int
  item            Int
  receivedPallets Int
  currentPallets  Int
  receivedCartons Int
  currentCartons  Int
  receivedSSPs    Int
  currentSSPs     Int
  vcp             Int
  ssp             Int
  status          String    @db.NVarChar(15)
  locationAisle   Int?
  locationBin     Int?
  locationLevel   Int?
  receivedByZ     String    @db.NVarChar(7)
  receivedAt      DateTime
  putByZ          String?   @db.NVarChar(7)
  putAt           DateTime?
  lastPulledByZ   String?   @db.NVarChar(7)
  lastPulledAt    DateTime?

  itemRef      Item      @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
  location     Location? @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  receivedBy   User      @relation("PalletReceivedBy", fields: [receivedByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  putBy        User?     @relation("PalletPutBy", fields: [putByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  lastPulledBy User?     @relation("PalletLastPulledBy", fields: [lastPulledByZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)

  labels       Label[]
  reservations Reservation[]
  activityLogs ActivityLog[]
}

model Label {
  lid              String    @id @db.NVarChar(36)
  pid              Int
  dept             Int
  class            Int
  item             Int
  quantity         Int
  sspQuantity      Int
  batchDate        Int
  purgeDate        DateTime  @db.Date
  destinationStore Int
  status           String    @db.NVarChar(15)
  pullFunction     String    @db.NVarChar(2)

  pallet  Pallet @relation(fields: [pid], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  itemRef Item   @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
  store   Store  @relation(fields: [destinationStore], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// Tracks active SDP reservations. One row per in-flight reservation; deleted on resolution.
model Reservation {
  id            Int      @id @default(autoincrement())
  locationAisle Int
  locationBin   Int
  locationLevel Int
  palletId      Int
  workerZ       String   @db.NVarChar(7)
  // Original search criteria — preserved so block/find-next can re-run the same query.
  targetAisle   Int
  targetSize    String?  @db.NVarChar(2)
  targetStorage String?  @db.NVarChar(2)
  targetZone    Int?
  // Preserved from the original directedPut call so a Blocked Put re-search (blockPut)
  // honors the same STAGED-exclusion preference as the initial search.
  consolidating Boolean  @default(false)
  createdAt     DateTime @default(now())

  location Location @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  pallet   Pallet   @relation(fields: [palletId], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  worker   User     @relation(fields: [workerZ], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
}

model ActivityLog {
  id            Int       @id @default(autoincrement())
  timestamp     DateTime  @default(now())
  userId        String    @db.NVarChar(7)
  actionType    String    @db.NVarChar(10)
  palletId      Int?
  locationAisle Int?
  locationBin   Int?
  locationLevel Int?
  dept          Int?
  class         Int?
  item          Int?
  details       String?   @db.NVarChar(Max)

  user     User      @relation(fields: [userId], references: [zNumber], onDelete: NoAction, onUpdate: NoAction)
  pallet   Pallet?   @relation(fields: [palletId], references: [pid], onDelete: NoAction, onUpdate: NoAction)
  location Location? @relation(fields: [locationAisle, locationBin, locationLevel], references: [aisle, bin, level], onDelete: NoAction, onUpdate: NoAction)
  itemRef  Item?     @relation(fields: [dept, class, item], references: [dept, class, item], onDelete: NoAction, onUpdate: NoAction)
}
