{
  "routes": [
    {
      "route": "/api/*",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,ico,png,jpg,gif,svg,woff,woff2}"]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/"
    }
  }
}
