# PalletIQ — .gitignore

# ---------- Dependencies ----------
node_modules/
**/node_modules/
.pnp
.pnp.js

# ---------- Build output ----------
dist/
build/
out/
.vite/
api/dist/

# ---------- Environment / secrets ----------
.env
.env.local
.env.*.local
.env.development
.env.production
*.env

# Azure Functions local settings (contains connection strings/secrets)
api/local.settings.json
api/local.settings.*.json

# ---------- Azure Functions / SWA artifacts ----------
api/bin/
api/obj/
.azure/
.swa/

# ---------- Azurite (local Azure Storage emulator) ----------
# Run with: azurite --location .azurite
.azurite/
__azurite_db_blob__.json
__azurite_db_blob_extent__.json
__azurite_db_queue__.json
__azurite_db_queue_extent__.json
__azurite_db_table__.json
__azurite_db_table_extent__.json
__blobstorage__/
__queuestorage__/
__tablestorage__/
**/debug.log

# ---------- Prisma ----------
# Generated client (regenerated via `prisma generate`, no need to commit)
api/node_modules/.prisma/
**/generated/prisma/

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Testing / coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- Playwright ----------
playwright-report/
test-results/
playwright/.auth/
blob-report/

# ---------- TypeScript ----------
*.tsbuildinfo

# ---------- Editor / IDE ----------

!.vscode/extensions.json
.idea/
*.swp
*.swo

# ---------- macOS artifacts ----------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ---------- Windows artifacts ----------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Personal / working notes (not part of the project deliverable) ----------
DevNotes/
.claude/

# ---------- Misc ----------
*.local
.cache/