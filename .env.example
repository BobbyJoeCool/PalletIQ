# PalletIQ — environment variable template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Azure SQL connection string (used by Prisma in api/)
# Format: sqlserver://<host>:<port>;database=<name>;user=<user>;password=<pass>;encrypt=true
DATABASE_URL=

# Azure Functions local base URL (for Vite dev proxy if needed)
VITE_API_BASE_URL=http://localhost:7071
