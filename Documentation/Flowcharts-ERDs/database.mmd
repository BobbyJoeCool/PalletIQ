erDiagram

    %% ============================================================
    %% COMPOSITE PRIMARY KEYS (Prisma @@id — not expressible in ERD)
    %% ============================================================
    %% Item:     @@id([dept, class, item], name: "DPCI")
    %% Location: @@id([aisle, bin, level], name: "LocationID")
    %% ============================================================
    %% ENUMS — stored as NVarChar strings (Prisma v7 SQL Server does not support enum blocks)
    %% LocationStatus: EMPTY, STORED, PULL_PENDING, RESERVED, STAGED                                           → NVarChar(15)
    %% HoldCategory:   HOLD_IN, HOLD_OUT, HOLD_BOTH, HOLD_PERM (Location.holdCategory, independent of status)   → NVarChar(10)
    %% LocationSize:   XS, HS, S, M, L                                                                         → NVarChar(2)
    %% PalletStatus:   PUT_PENDING, STORED, PULL_PENDING, PULLED, CANCELED, CONSOLIDATED (open — expand as needed) → NVarChar(15)
    %% LabelStatus:    AVAILABLE, PRINTED, PULLED, DIVERTED, CANCELED, PURGED                                  → NVarChar(15)
    %% PullFunction:   CA (Carton Air), CF (Carton Floor), FP (Full Pallet), BK (Bulk/level-0, not in demo)   → NVarChar(2)
    %% Role:           ADMIN, MANAGER, LEAD, IM, WORKER                                                        → NVarChar(10)
    %% ActionType:     EDIT_PAL, PULL, RESERVE, PUT, UNASSIGN, BLOCK_PUT, RES_TMOUT, MNP_SCAN, STAGE, RESTAGE,
    %%                 HOLD_PLACE, HOLD_CLEAR, REINSTATE                                                       → NVarChar(10)
    %% ============================================================
    %% BUSINESS RULES
    %% SSP must be a factor of VCP (enforced in app logic, not schema)
    %% LID format: {storeCode(1-4)}{DPCI(9)}{pid(8)}{random(8)}{batchDate(7)} = NVarChar(36)
    %% DPCI(9) is zero-padded: dept(3) + class(2) + item(4)
    %% pid: app-generated 8-digit Int with collision check
    %% zNumber format: z###x## (z + 3 digits + 1 letter + 2 digits) = NVarChar(7)
    %% PurgeDate defaults to 7 days after batchDate, set at label creation in app logic
    %% Status change to PURGED triggered in app logic on purge date
    %% ActionType enum must be defined and expanded as features are built
    %% Location.holdTypeCode (reason-code FK) is unpopulated — WLH.md states the reason
    %% code is written only to ActivityLog.details, never stored as a column (Phase 10)
    %% ============================================================

    Item {
        int dept PK "3 digits"
        int class PK "2 digits"
        int item PK "4 digits"
        string upc "unique NVarChar(12)"
        string name "NVarChar(50)"
        string desc "NVarChar(Max)"
        string descShort "NVarChar(155)"
        decimal retailPrice "Decimal(10,2)"
        decimal cost "Decimal(10,2)"
        int packingZoneCode FK "→ PackingZone"
        string storageCode FK "NVarChar(2) → StorageCode"
        boolean conveyable "default: true"
        boolean requiresExpirationDate "default: false, v1.6.7 — per-DPCI setting, seeded true for food Storage Codes (FD/NF/RF); not derived from storageCode at runtime"
        decimal unitWeight "nullable, Decimal(10,2), v1.6.8 — pounds, displayed on IID"
    }

    PackingZone {
        int id PK "2-digit int"
        string desc "NVarChar(60)"
    }

    StorageCode {
        string id PK "NVarChar(2)"
        string desc "NVarChar(60)"
    }

    Location {
        int aisle PK "3 digits"
        int bin PK "3 digits"
        int level PK "2 digits"
        int zone "raw int, set by aisle"
        string status "NVarChar(15), LocationStatus values"
        string holdTypeCode FK "nullable, NVarChar(3) → HoldType — reason code; unused, see comment below"
        string holdCategory "nullable, NVarChar(10), HoldCategory values — independent of status, added Phase 10"
        string storageCode FK "NVarChar(2) → StorageCode"
        string size "NVarChar(2), LocationSize values"
        boolean contraction "default: false, set by Lead+ via Aisle Setup (out of scope) — read-only in this app"
    }

    HoldType {
        string code PK "NVarChar(3) → 1 letter (Department) 2 numbers (Reason)"
        string desc "NVarChar(20)"
    }

    Pallet {
        int pid PK "8-digit app-generated"
        int dept FK "composite FK → Item"
        int class FK "composite FK → Item"
        int item FK "composite FK → Item"
        int receivedPallets
        int currentPallets
        int receivedCartons
        int currentCartons
        int receivedSSPs
        int currentSSPs
        int vcp "Vendor Case Pack, eaches per carton"
        int ssp "Store Ship Pack, must be factor of vcp"
        string status "NVarChar(15), PalletStatus values"
        int locationAisle FK "nullable → Location"
        int locationBin FK "nullable → Location"
        int locationLevel FK "nullable → Location"
        string storageCode FK "nullable, NVarChar(2) → StorageCode — inherited from wherever currently STORED, null if PUT_PENDING"
        string size "nullable, NVarChar(2) — inherited from wherever currently STORED, null if PUT_PENDING"
        int zone "nullable — inherited from wherever currently STORED, null if PUT_PENDING"
        string receivedByZ FK "NVarChar(7) → User"
        datetime receivedAt
        string putByZ FK "nullable, NVarChar(7) → User"
        datetime putAt "nullable"
        string lastPulledByZ FK "nullable, NVarChar(7) → User"
        datetime lastPulledAt "nullable"
        string poNumber "nullable, NVarChar(20), v1.6.7 — receiving-side identifier, null on a PAR-reinstated pallet, read-only from every screen"
        string apptNumber "nullable, NVarChar(20), v1.6.7 — receiving-side identifier, same null/read-only rules as poNumber"
        date expirationDate "nullable, db.Date, v1.6.7 — editable via PII Edit Mode (IM+); 1-month floor / 3-month confirm gate enforced in app logic"
    }

    Label {
        string lid PK "NVarChar(36), app-generated composite"
        int pid FK "→ Pallet"
        int dept FK "composite FK → Item"
        int class FK "composite FK → Item"
        int item FK "composite FK → Item"
        int quantity "non-breakpack full cartons"
        int sspQuantity "SSPs to packers"
        int batchDate "Julian date e.g. 2026175"
        date purgeDate "db.Date, default 7 days after batchDate"
        int destinationStore FK "→ Store"
        string status "NVarChar(15), LabelStatus values"
        string pullFunction "NVarChar(2), PullFunction values, default CA"
    }

    Store {
        int id PK "4-digit store code"
        string name "NVarChar(40)"
    }

    User {
        string zNumber PK "NVarChar(7), format z###x##"
        string firstName "NVarChar(50)"
        string lastName "NVarChar(50)"
        string pinHash "NVarChar(60)"
        string role "NVarChar(10), Role values"
        string departmentId FK "NVarChar(3) → Department"
    }

    Department {
        string id PK "NVarChar(3)"
        string name "INB, OUT, WHS, BKP, SEC, IQA"
    }

    Reservation {
        int id PK "autoincrement"
        int locationAisle FK "→ Location"
        int locationBin FK "→ Location"
        int locationLevel FK "→ Location"
        int palletId FK "→ Pallet"
        string workerZ FK "NVarChar(7) → User"
        int targetAisle "original search aisle"
        string targetSize "nullable, NVarChar(2)"
        string targetStorage "nullable, NVarChar(2)"
        int targetZone "nullable"
        boolean consolidating "default: false, preserved for Blocked Put re-search"
        boolean pidWasScanned "nullable — Scan vs Enter verification-method tracking, see ActivityLog.details.verification"
        boolean wasStaged "nullable — whether the location was already STAGED when directed, see confirmPut"
        datetime createdAt "auto-set on creation"
    }

    ActivityLog {
        int id PK "autoincrement"
        datetime timestamp "auto-set on creation"
        string userId FK "NVarChar(7) → User"
        string actionType "NVarChar(10), ActionType values, TBD"
        int palletId FK "nullable → Pallet"
        int locationAisle FK "nullable → Location"
        int locationBin FK "nullable → Location"
        int locationLevel FK "nullable → Location"
        int dept FK "nullable → Item"
        int class FK "nullable → Item"
        int item FK "nullable → Item"
        string details "nullable, NVarChar(Max), free JSON notes"
    }

    %% ============================================================
    %% RELATIONS
    %% ============================================================

    Item }o--|| PackingZone : "packingZoneCode"
    Item }o--|| StorageCode : "storageCode"

    Location }o--o| HoldType : "holdTypeCode (nullable)"
    Location }o--|| StorageCode : "storageCode"

    Pallet }o--|| Item : "dept/class/item"
    Pallet }o--o| Location : "locationAisle/Bin/Level (nullable)"
    Pallet }o--o| StorageCode : "storageCode (nullable)"
    Pallet }o--|| User : "receivedByZ"
    Pallet }o--o| User : "putByZ (nullable)"
    Pallet }o--o| User : "lastPulledByZ (nullable)"

    Label }o--|| Pallet : "pid"
    Label }o--|| Item : "dept/class/item"
    Label }o--|| Store : "destinationStore"

    User }o--|| Department : "departmentId"

    Reservation }o--|| Location : "locationAisle/Bin/Level"
    Reservation }o--|| Pallet : "palletId"
    Reservation }o--|| User : "workerZ"

    ActivityLog }o--|| User : "userId"
    ActivityLog }o--o| Pallet : "palletId (nullable)"
    ActivityLog }o--o| Location : "locationAisle/Bin/Level (nullable)"
    ActivityLog }o--o| Item : "dept/class/item (nullable)"
